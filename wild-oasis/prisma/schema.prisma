// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  name String
  passwordHash String
  createdAt DateTime @default(now())
}

model Cabin {
  id Int      @id @default(autoincrement())
  name String @unique
  maxCapacity Int
  regularPrice Float
  discount Float?
  description String?
  image Bytes?
  bookings Bookings[]
  updated DateTime @default(now())
}

model Guests {
  id Int      @id @default(autoincrement())
  fullName String
  email String @unique
  nationality String
  countryFlag String
  nationalId String
  bookings Bookings[]
  updated DateTime @default(now())
}

model Settings {
  id Int      @id @default(autoincrement())
  minBookingLength Int
  maxBookingLength Int
  maxGuestNumberPerBooking Int
  breakfastPrice Float
  updated DateTime @default(now())
}

model Bookings {
  id Int      @id @default(autoincrement())
  startDate DateTime
  endDate DateTime
  numberOfNights Int
  numberOfGuests Int
  cabinPrice Float
  extraPrice Float
  totalPrice Float
  status String
  hasBreakfast Boolean
  hasPaid Boolean
  notes String
  cabin Cabin @relation(fields: [cabinId], references: [id])
  cabinId Int
  guest Guests @relation(fields: [guestId], references: [id])
  guestId Int
  createdAt DateTime @default(now())
  updated DateTime @default(now())
}